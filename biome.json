{
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "apps/web/src/**/*.{js,jsx,ts,tsx,css,scss}",
      "apps/web/tailwind.config.js"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noUndeclaredDependencies": "error"
      },
      "suspicious": {
        "noRedeclare": "error"
      },
      "style": {
        "noCommonJs": "error"
      }
    }
  },
  "formatter": {
    "enabled": false
  },
  "css": {
    "parser": {
      "cssModules": false,
      "allowWrongLineComments": false,
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["tailwind.config.js"],
      "linter": {
        "rules": {
          "style": {
            "noCommonJs": "off"
          }
        }
      }
    }
  ]
}
